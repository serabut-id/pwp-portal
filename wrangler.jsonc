{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pwp-portal",
  "compatibility_date": "2026-04-03",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "workers_dev": true,
  "routes": [
    { "pattern": "pwp.serabut.id", "custom_domain": true }
  ]
}
